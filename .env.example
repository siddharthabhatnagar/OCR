# Local development environment. Copy to .env and edit.
# On HF Spaces, set the same keys as Space Variables/Secrets.

MODEL_ID=baidu/Unlimited-OCR
MODEL_DTYPE=bfloat16
PDF_DPI=144
PDF_MAX_PAGES=50
CHUNK_SIZE=4
MAX_NEW_TOKENS=16384
MAX_CONCURRENT_REQUESTS=4

# Auth (optional) — leave blank to disable.
API_KEY=

# HF token — needed if model is gated or to avoid rate limits.
HF_TOKEN=
